TestFont.Test(1, 2, 1)     ' русский  

Klav.Klav("/0DDTLBNT BVZ", Name)          ' вводим имя, например, игрока с подсказкой
Klav.Klav("/0DDTLBNT GFHJKM", PAROL)      ' вводим пароль с подсказкой

LCDRu.TextRu(1, 0, 20, 2, "Buhjr/a: /r" + Name)
LCDRu.TextRu(1, 0, 40, 2, "Gfhjkm/a: /r" + PAROL)
Buttons.Flush()
Buttons.Wait()